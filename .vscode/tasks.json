{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "Initial Repo Setup",
      "command": "${workspaceFolder}/Tools/setupRepo.ps1",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "Verify Repo Settings",
      "command": "${workspaceFolder}/Tools/checkRepo.ps1",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "group": "none",
      "problemMatcher": []
    }
  ]
}